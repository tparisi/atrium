{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Remove",
  "description": "Remove a node from the scene graph",
  "type": "object",
  "required": ["type", "seq", "node"],
  "properties": {
    "type": { "const": "remove" },
    "seq": { "type": "integer", "minimum": 0 },
    "node": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}