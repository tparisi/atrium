{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "view (client)",
  "type": "object",
  "required": ["type", "seq", "position"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "view" },
    "seq": { "type": "integer", "minimum": 0 },
    "position": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "look": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3,
      "description": "Unit vector: direction the client is looking"
    },
    "move": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3,
      "description": "Unit vector: direction the client is moving (may differ from look)"
    },
    "velocity": {
      "type": "number",
      "minimum": 0,
      "description": "Scalar speed in units/second"
    },
    "up": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3,
      "description": "Up unit vector. Defaults to [0,1,0] if omitted. Only sent when non-default (FLY mode, vehicles)."
    }
  }
}
