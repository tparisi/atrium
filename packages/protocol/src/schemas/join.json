{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Join",
  "description": "Avatar entered the world",
  "type": "object",
  "required": ["type", "seq", "id"],
  "properties": {
    "type": { "const": "join" },
    "seq": { "type": "integer", "minimum": 0 },
    "id": { "type": "string", "minLength": 1 },
    "avatar": {
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "avatarURL": { "type": "string" },
        "position": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "rotation": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}