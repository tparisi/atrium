{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Add",
  "description": "Add a node to the scene graph",
  "type": "object",
  "required": ["type", "seq", "node"],
  "properties": {
    "type": { "const": "add" },
    "seq": { "type": "integer", "minimum": 0 },
    "format": { "type": "string", "default": "gltf" },
    "parent": { "type": "string" },
    "node": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "translation": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "rotation": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "scale": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        },
        "extras": { "type": "object" },
        "extensions": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}